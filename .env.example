# Copie para .env e preencha. O .env é ignorado pelo Git.
OPENROUTER_API_KEY=

# Opcionais (valores padrão mostrados)
#AKITA_TEXT_MODEL=google/gemini-2.5-pro
#AKITA_AUDIT_MODEL=google/gemini-2.5-flash
#AKITA_TTS_MODEL=google/gemini-3.1-flash-tts-preview
#AKITA_VOICE_A=Kore
#AKITA_VOICE_B=Puck
# Gemini TTS só aceita "pcm" (o pipeline embrulha em WAV); outros modelos podem aceitar mp3/wav
#AKITA_TTS_FORMAT=pcm
#AKITA_TTS_SAMPLE_RATE=24000
